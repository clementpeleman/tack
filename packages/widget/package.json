{
  "name": "@tack/widget",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "types": "index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js"
